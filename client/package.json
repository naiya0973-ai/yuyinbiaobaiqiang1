{
  "name": "voice-confession-wall-client",
  "version": "1.0.0",
  "description": "Voice Confession Wall - uni-app Client",
  "main": "main.js",
  "scripts": {
    "dev:h5": "set UNI_INPUT_DIR=.&& uni",
    "dev:mp-weixin": "set UNI_INPUT_DIR=.&& uni --open --mode mp-weixin",
    "dev:app": "set UNI_INPUT_DIR=.&& uni --open --mode app",
    "build:h5": "uni build",
    "build:mp-weixin": "set UNI_INPUT_DIR=.&& uni build --mode mp-weixin",
    "build:app": "set UNI_INPUT_DIR=.&& uni build --mode app"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-4010520240507001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-4010520240507001",
    "@dcloudio/uni-h5": "3.0.0-alpha-4010520240507001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-4010520240507001",
    "vue": "^3.3.0",
    "vuex": "^4.0.0",
    "pinia": "^2.1.0"
  },
  "devDependencies": {
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-4010520240507001",
    "vite": "^5.2.8"
  }
}
