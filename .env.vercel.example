# Vercel 环境变量模板
# 在 Vercel Dashboard → Settings → Environment Variables 中配置

NODE_ENV=production
JWT_SECRET=your-random-jwt-secret-at-least-32-chars
JWT_EXPIRES=7d

# Supabase（必填）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 演示登录验证码（未接入短信前使用）
DEMO_SMS_CODE=123456

# Supabase Storage（Vercel 部署必填，用于音频上传）
USE_SUPABASE_STORAGE=true
SUPABASE_STORAGE_AUDIO_BUCKET=audios

# GitHub Pages 前端跨域访问 API 时必填
CLIENT_ORIGIN=https://naiya0973-ai.github.io
ADMIN_ORIGIN=https://naiya0973-ai.github.io
