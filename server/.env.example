# Server Configuration
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_AUDIO_BUCKET=audios
SUPABASE_STORAGE_AVATAR_BUCKET=avatars

# Legacy Database Configuration (before Supabase migration)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=voice_confession_wall

# Legacy Redis Configuration (before Supabase migration)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES=7d

# Client Configuration (CORS)
CLIENT_ORIGIN=http://localhost:8080

# Tencent Cloud COS Configuration (Optional - for production)
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-guangzhou

# Tencent Cloud SMS Configuration (Optional - for production)
SMS_SECRET_ID=your_sms_secret_id
SMS_SECRET_KEY=your_sms_secret_key
SMS_APP_ID=your_sms_app_id
SMS_SIGN_NAME=your_sign_name
SMS_TEMPLATE_ID=your_template_id
